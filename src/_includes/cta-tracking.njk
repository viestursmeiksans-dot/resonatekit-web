  <!-- ══════════════════════ PER-BUTTON CLICK TRACKING (GA4 cta_click) ══════════════════════ -->
  <!-- Fires cta_click on every link/button/checkbox with text + location + destination + scroll depth.
       Feeds the "Resonate Clicks" analysis tab. Needs GA4 custom dimensions registered on prop 541724382:
       cta_text, cta_location, link_url, scroll_pct (event-scoped). -->
  <script>
    (function () {
      if (window.rkCtaInit) return; window.rkCtaInit = 1;
      function ev(n, p) { if (window.gtag) gtag('event', n, p || {}); }
      function locOf(el) {
        var s = el.closest('section,header,nav,footer,form');
        if (s && s.id) return s.id;
        if (s) { var h = s.querySelector('h1,h2,h3,h4'); if (h) return (h.innerText || '').replace(/\s+/g, ' ').trim().slice(0, 40); }
        return el.closest('nav') ? 'nav' : (el.closest('footer') ? 'footer' : '(page)');
      }
      function depth() {
        var h = document.documentElement, sc = h.scrollHeight - h.clientHeight;
        return sc > 0 ? Math.round(window.scrollY / sc * 100) : 0;
      }
      document.addEventListener('click', function (e) {
        var el = e.target.closest && e.target.closest('a,button'); if (!el) return;
        var h = el.getAttribute('href') || '';
        var loc = locOf(el);
        var txt = el.getAttribute('data-cta') || (el.innerText || el.textContent || '').replace(/\s+/g, ' ').trim().slice(0, 60);
        // Per-goal attribution: the contact/quote modals are SHARED across goals, so stamp the last
        // selected goal onto the Send so each goal's funnel collects distinct numbers.
        if (/^(send|send message|send request)/i.test(txt) && /ask-form|corp-form|quote-summary/i.test(loc) && window.rkLastGoal) {
          txt = txt + ' · ' + window.rkLastGoal;
        }
        ev('cta_click', { cta_text: txt || '(no text)', cta_location: loc, link_url: h, scroll_pct: depth() });
      }, true);
      document.addEventListener('change', function (e) {
        var el = e.target; if (!el || el.type !== 'checkbox' || !el.checked) return;
        if (el.value) window.rkLastGoal = el.value.replace(/\s+/g, ' ').trim().slice(0, 50); // remember active goal for Send attribution
        var loc = el.getAttribute('data-cat') ? ('Goal: ' + el.getAttribute('data-cat')) : 'Selection';
        ev('cta_click', { cta_text: (el.value || '(choice)').slice(0, 100), cta_location: loc, link_url: '', scroll_pct: depth() });
      }, true);
      // Scroll-depth milestones (25/50/75/100) — granular scroll-depth for the Traffic tab.
      var _sf = {};
      window.addEventListener('scroll', function () {
        var p = depth();
        [25, 50, 75, 100].forEach(function (m) { if (p >= m && !_sf[m]) { _sf[m] = 1; ev('scroll_' + m, { percent_scrolled: m }); } });
      }, { passive: true });
    })();
  </script>

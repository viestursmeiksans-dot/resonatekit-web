  <!-- ══════════════════════ STICKY CTA BAR (desktop + mobile) ══════════════════════ -->
  <div id="rk-sticky">
    <div class="rk-sticky-inner">
      <a href="{{ stickyHref }}" class="rk-sticky-btn" data-cta="Sticky bar · {{ stickyText }}">{{ stickyText }}</a>
    </div>
  </div>
  <style>
    #rk-sticky{position:fixed;left:0;right:0;bottom:0;z-index:60;
      padding:.6rem .8rem calc(.6rem + env(safe-area-inset-bottom));
      background:rgba(255,255,255,.96);-webkit-backdrop-filter:blur(8px);backdrop-filter:blur(8px);
      border-top:1px solid rgba(0,0,0,.08);box-shadow:0 -4px 20px rgba(0,0,0,.06);}
    #rk-sticky .rk-sticky-inner{max-width:42rem;margin:0 auto;display:flex;}
    #rk-sticky .rk-sticky-btn{flex:1;display:inline-flex;align-items:center;justify-content:center;text-align:center;
      padding:.85rem 1rem;border-radius:.75rem;font-weight:700;font-size:13px;letter-spacing:.04em;text-transform:uppercase;color:#000;
      background:#8AE14A;transition:background .15s,color .15s;}
    #rk-sticky .rk-sticky-btn:hover{background:#E07B6A !important;color:#fff !important;}
    body{padding-bottom:5rem;}
  </style>

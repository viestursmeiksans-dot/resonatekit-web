        <div><label class="block text-xs uppercase tracking-widest text-neutral-500 mb-1.5" for="c-message">What does your team need?</label><textarea id="c-message" rows="4" placeholder="Team size, goals, programs you're interested in, timing…" class="w-full border border-neutral-300 rounded-xl px-4 py-3 text-sm text-black placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-black resize-none transition"></textarea></div>
      </div>
      <p id="c-error" class="hidden text-sm text-[#c53b3b] mt-3">Please fill in your name, email and phone.</p>
      <button type="button" id="c-submit" class="mt-5 w-full text-center text-sm font-bold tracking-widest uppercase px-6 py-3.5 rounded-xl border border-black text-black hover:bg-[#E07B6A] hover:text-white transition-colors" style="background:#8AE14A;">Send request</button>
      <div id="c-confirmed" class="hidden text-center py-6">
        <div class="w-12 h-12 rounded-full bg-[#f5f0eb] border border-neutral-200 flex items-center justify-center mx-auto mb-4"><svg class="w-6 h-6 text-[#2f7a3d]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75" /></svg></div>
        <h3 class="font-serif text-2xl text-neutral-900 mb-1">Thank you!</h3>
        <p class="text-sm text-neutral-500">We'll get back to you within 24 hours.</p>
      </div>
    </div>
    <p class="text-center text-white/50 text-sm mt-6">Or email <a href="mailto:hello@resonatekit.com" class="text-white underline hover:no-underline">hello@resonatekit.com</a> · <a href="tel:+37127337711" class="text-white underline hover:no-underline">+371 27 337 711</a></p>
  </div>
</section>

<script>
  (function () {
    const submit = document.getElementById('c-submit');
    const err = document.getElementById('c-error');
    const ok = document.getElementById('c-confirmed');
    if (!submit) return;
    submit.addEventListener('click', async () => {
      const name = (document.getElementById('c-name').value || '').trim();
      const company = (document.getElementById('c-company').value || '').trim();
      const email = (document.getElementById('c-email').value || '').trim();
      const phone = (document.getElementById('c-phone').value || '').trim();
      const message = (document.getElementById('c-message').value || '').trim();
      if (!name || !email || !phone) { err.classList.remove('hidden'); return; }
      err.classList.add('hidden');
      const orig = submit.textContent; submit.disabled = true; submit.textContent = 'Sending...';
      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST', headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({
            access_key: RK_WEB3.key, cc: RK_WEB3.cc,
            subject: 'Corporate training request — ResonateKit',
            from_name: 'ResonateKit — Corporate training',
            name: name, company: company || '—', email: email, phone: phone, message: message || '—'
          })
        });
        const d = await res.json();
        if (d && d.success) {
          submit.parentElement.querySelectorAll('.space-y-3, #c-submit, #c-error').forEach(el => el.classList.add('hidden'));
          ok.classList.remove('hidden');
          try { gtag('event', 'generate_lead', { lead_type: 'corporate' }); fbq('track', 'Lead', { content_name: 'corporate' }); } catch (e) {}
        } else { throw new Error('fail'); }
      } catch (e) {
        submit.disabled = false; submit.textContent = orig;
        err.textContent = 'Could not send. Please email hello@resonatekit.com.'; err.classList.remove('hidden');
      }
    });
  })();
</script>


    <script>
      (function () {
        var track = document.getElementById('blog-track');
        if (!track) return;
        function step() { var c = track.querySelector(':scope > a'); return c ? c.offsetWidth + 20 : 320; }
        var prev = document.getElementById('blog-prev'), next = document.getElementById('blog-next');
        if (prev) prev.addEventListener('click', function () { track.scrollBy({ left: -step(), behavior: 'smooth' }); });
        if (next) next.addEventListener('click', function () { track.scrollBy({ left: step(), behavior: 'smooth' }); });
      })();
    </script>

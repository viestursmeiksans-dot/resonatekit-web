              access_key: RK_WEB3.key,
              cc: RK_WEB3.cc,
              subject: 'ResonateKit request: ' + program,
              from_name: 'ResonateKit — Company request',
              name: name,
              email: email,
              phone: phone,
              program: program,
              comment: comment || '—'

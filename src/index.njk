  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
    }

    html {
      overflow-x: hidden;
      scroll-behavior: smooth;
      max-width: 100%;
    }

    body {
      -webkit-font-smoothing: antialiased;
      margin: 0;
      background: #f5f0eb;
      overflow-x: hidden;
      max-width: 100%;
    }

    .hero-video {
      width: 100%; height: 100%;
      object-fit: cover;
      pointer-events: none;
      border: 0;
    }

    /* Brighten photography & video across the site */
    img { filter: brightness(1.12); }
    video.hero-video { filter: brightness(1.30); }
    .hero-slide { filter: brightness(1.12); }
    .hero-bg {
      background: #0a0a0a;
    }
    .hero-slide {
      position: absolute;
      inset: 0;
      background-size: cover;
      background-position: center center;
      opacity: 0;
      animation: heroFade 18s infinite ease-in-out;
    }
    .hero-slide.s1 {
      background-image: url('https://cdn.shopify.com/s/files/1/0303/7134/8525/files/hero-new1.jpg?width=1920');
      animation-delay: 0s;
    }
    .hero-slide.s2 {
      background-image: url('https://cdn.shopify.com/s/files/1/0303/7134/8525/files/liaa-v2.png?width=900');
      animation-delay: 6s;
    }
    .hero-slide.s3 {
      background-image: url('https://cdn.shopify.com/s/files/1/0303/7134/8525/files/liaa-v3.png?width=900');
      animation-delay: 12s;
    }
    @keyframes heroFade {
      0%    { opacity: 0; }
      3%    { opacity: 1; }
      33%   { opacity: 1; }
      36%   { opacity: 0; }
      100%  { opacity: 0; }
    }

    .hero-overlay {
      background: linear-gradient(to right, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.4) 50%, rgba(0,0,0,0.2) 75%, rgba(0,0,0,0.05) 100%), linear-gradient(to top, rgba(0,0,0,0.25) 0%, transparent 40%);
    }

    @media (max-width: 767px) {
      .hero-slide {
        background-position: 62% center;
      }

      .hero-overlay {
        background: linear-gradient(to top, rgba(0,0,0,0.45) 0%, rgba(0,0,0,0.18) 35%, rgba(0,0,0,0) 60%);
      }

      #hero-word-wrap {
        margin-top: 0.1em !important;
        max-width: none !important;
      }

      #hero-word {
        white-space: nowrap;
        font-size: clamp(1.672rem, 5.5vw, 5rem) !important;
        color: #ffffff !important;
      }
    }

    .hero-cta:hover {
      background: #E07B6A !important;
    }

    /* Rotating hero word */
    @keyframes slideUp {
      from { opacity: 0; transform: translateY(50px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes slideDown {
      from { opacity: 1; transform: translateY(0); }
      to { opacity: 0; transform: translateY(-50px); }
    }
    .word-enter { animation: slideUp 0.55s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
    .word-exit { animation: slideDown 0.4s cubic-bezier(0.22, 1, 0.36, 1) forwards; }

    #hero-word-wrap {
      overflow: hidden;
      display: inline-block;
      vertical-align: bottom;
      padding-bottom: 0.18em;
      margin-bottom: -0.18em;
    }

    /* Marquee */
    @keyframes marquee {
      from { transform: translateX(0); }
      to { transform: translateX(-50%); }
    }
    .marquee-track { animation: marquee 44s linear infinite; }
    .marquee-logos { animation: marquee 40s linear infinite; }
    .marquee-logos > * { margin-right: 3rem; }
    .marquee-logos:hover { animation-play-state: paused; }
    @media (max-width: 767px) {
      .marquee-logos { animation-duration: 40s; }
    }

    .logo-mark {
      height: 36px;
      width: 140px;
      object-fit: contain;
      filter: grayscale(100%);
      opacity: 0.55;
      transition: opacity .2s ease, filter .2s ease;
      flex-shrink: 0;
    }
    .logo-mark:hover {
      filter: grayscale(0);
      opacity: 1;
    }

    .logo-name {
      font-size: 0.875rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: oklch(43.9% 0 0);
      opacity: 0.7;
      flex-shrink: 0;
      transition: opacity .2s ease, color .2s ease;
    }
    .logo-name:hover {
      opacity: 1;
      color: oklch(20.5% 0 0);
    }

    /* Fade in */
    .reveal {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.55s ease, transform 0.55s ease;
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* Program selector */
    .tx-tab { color: #6b6155; }
    .tx-tab.tx-tab-active { background: #3d2d5e; color: #fff; }

    .tx-list { list-style: none; padding: 0; margin: 0; }
    .tx-list li + li { border-top: 1px solid rgba(0, 0, 0, 0.08); }
    .tx-list li { border-bottom: 1px solid rgba(0, 0, 0, 0.08); }

    .tx-row {
      display: flex;
      align-items: center;
      gap: 1.25rem;
      padding: 1.25rem 0.25rem;
      cursor: pointer;
      transition: padding-left .25s ease;
    }
    .tx-row:hover { padding-left: 0.5rem; }

    .tx-cb {
      position: absolute;
      opacity: 0;
      pointer-events: none;
    }

    .tx-num {
      color: rgba(0, 0, 0, 0.35);
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      width: 2rem;
      flex-shrink: 0;
    }

    .tx-info {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      min-width: 0;
    }

    .tx-name {
      color: #1f1f1f;
      font-size: 1.05rem;
      font-weight: 400;
      letter-spacing: -0.01em;
    }

    .tx-unit {
      color: #8a8377;
      font-size: 0.75rem;
      font-weight: 400;
      margin-left: 0.4rem;
    }

    .tx-meta {
      font-size: 0.8rem;
      color: #8a8377;
    }

    .tx-row:has(.tx-cb:checked) .tx-name { font-weight: 500; }

    .tx-mark {
      width: 1.5rem;
      height: 1.5rem;
      border-radius: 0.3rem;
      border: 1.5px solid rgba(0, 0, 0, 0.3);
      background: #fff;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: border-color .15s ease, background-color .15s ease;
      position: relative;
    }

    .tx-mark::after {
      content: "";
      position: absolute;
      width: 10px;
      height: 5px;
      border-left: 2px solid #000;
      border-bottom: 2px solid #000;
      transform: rotate(-45deg) translate(1px, -1px);
      opacity: 0;
      transition: opacity .15s ease;
    }

    .tx-row:has(.tx-cb:checked) .tx-mark { border-color: #000; }
    .tx-row:has(.tx-cb:checked) .tx-mark::after { opacity: 1; }

    /* Quote summary cards */
    .qs-card {
      transition: border-color .15s ease, background-color .15s ease;
    }
    .qs-card:has(:checked) {
      border-color: #000;
      background: #fafafa;
    }
  </style>


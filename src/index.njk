                  '<h4 class="font-serif text-xl text-neutral-900 mb-1">Thank you!</h4>' +
                  '<p class="text-sm text-neutral-500">We\'ll get back to you the same day.</p>' +
                '</div>';
            } else {
              throw new Error((data && data.message) || 'Submit failed');
            }

            const cat = cb.dataset.cat;
            document.querySelectorAll('.tx-cb[data-cat="' + cat + '"]').forEach(other => {
              if (other !== cb && other.checked) {
                other.checked = false;
                other.dispatchEvent(new Event('change', { bubbles: true }));
              }
            });
          }
          if (cb.dataset.cat === 'individual') refreshIndividualPanel();
          refresh();
          if (cb.checked && cb.dataset.cat === 'individual') {
            const id = individualPanels[cb.value];
            const elp = id && document.getElementById(id);
            if (elp) setTimeout(() => {
              const top = window.pageYOffset + elp.getBoundingClientRect().top - 80;
              window.scrollTo({ top, behavior: 'smooth' });
            }, 120);
          }
        });
      });

      if (cta) cta.addEventListener('click', (e) => {
        e.preventDefault();
        const checked = document.querySelectorAll('.tx-cb:checked');
        if (checked.length === 0) {
          if (errorEl) errorEl.classList.remove('hidden');
          return;
        }
        if (errorEl) errorEl.classList.add('hidden');
        qsSelected.innerHTML = '';
        checked.forEach(cb => {
          const li = document.createElement('li');
          li.className = 'flex items-center justify-between gap-3';
          li.innerHTML = '<span>' + cb.value + '</span>';
          qsSelected.appendChild(li);
        });
        quoteSection.classList.remove('hidden');
        setTimeout(() => quoteSection.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
      });
    })();

    // Quote summary submit → Web3Forms
    (function () {
      const submitBtn = document.getElementById('qs-submit');
      if (!submitBtn) return;
      const firstEl = document.getElementById('qs-first');
      const lastEl = document.getElementById('qs-last');
      const phoneEl = document.getElementById('qs-phone');
      const emailEl = document.getElementById('qs-email');
      const errEl = document.getElementById('qs-error');
      const confirmedEl = document.getElementById('qs-confirmed');

      submitBtn.addEventListener('click', async () => {
        const first = firstEl.value.trim();
        const last = lastEl.value.trim();
        const phone = phoneEl.value.trim();
        const email = emailEl.value.trim();
        if (!first || !last || !phone || !email) {
          errEl.classList.remove('hidden');
          return;
        }
        errEl.classList.add('hidden');

        const programs = Array.from(document.querySelectorAll('#qs-selected li')).map(li => li.textContent.trim()).join(', ');
        const format = (document.querySelector('input[name="qs-format"]:checked') || {}).value || '—';
        const when = (document.querySelector('input[name="qs-when"]:checked') || {}).value || '—';
        const orig = submitBtn.textContent;
        submitBtn.disabled = true;
        submitBtn.textContent = 'Sending...';
        try {
          await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({
              access_key: RK_WEB3.key,
              cc: RK_WEB3.cc,
              subject: 'ResonateKit proposal request',
              from_name: 'ResonateKit — Proposal request',
              name: first + ' ' + last,
              email: email,
              phone: phone,
              programs: programs || '—',
              format: format,
              timing: when
            })
          });
        } catch (e) { /* show confirmation regardless */ }
        submitBtn.classList.add('hidden');
        confirmedEl.classList.remove('hidden');
        setTimeout(() => confirmedEl.scrollIntoView({ behavior: 'smooth', block: 'center' }), 50);
      });
    })();
  </script>

  <!-- ══════════════════════ CONTACT MODAL ══════════════════════ -->
  <div id="kontakti-modal" class="hidden fixed inset-0 z-[999]">
    <div id="kontakti-backdrop" class="absolute inset-0 bg-black/60"></div>
    <div class="relative h-full w-full flex items-center justify-center p-4">
      <div class="relative w-full max-w-md bg-white rounded-2xl shadow-2xl p-6 md:p-8 max-h-[92vh] overflow-y-auto">
        <button type="button" id="kontakti-close" class="absolute top-4 right-4 w-9 h-9 rounded-full flex items-center justify-center text-neutral-500 hover:bg-neutral-100 transition-colors" aria-label="Close">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
        <h3 class="font-serif text-2xl text-neutral-900 mb-2">Contact</h3>
        <p class="text-sm text-neutral-500 mb-5">Reach us directly or leave a message — we reply as soon as possible.</p>
        <div class="flex flex-col gap-2 mb-5 text-sm">
          <a href="mailto:hello@resonatekit.com" class="inline-flex items-center gap-2 text-neutral-700 hover:text-neutral-900 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
            hello@resonatekit.com
          </a>
          <a href="tel:+37127337711" class="inline-flex items-center gap-2 text-neutral-700 hover:text-neutral-900 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
            +371 27 337 711
          </a>
        </div>
        <form id="kontakti-form" class="space-y-3">
          <input id="kontakti-name" type="text" placeholder="Name" class="w-full border border-neutral-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-neutral-900 transition" />
          <input id="kontakti-email" type="email" placeholder="Email" class="w-full border border-neutral-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-neutral-900 transition" />
          <input id="kontakti-phone" type="tel" placeholder="Phone (optional)" class="w-full border border-neutral-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-neutral-900 transition" />
          <textarea id="kontakti-comment" rows="4" placeholder="Your message…" class="w-full border border-neutral-300 rounded-xl px-4 py-3 text-sm resize-none focus:outline-none focus:ring-2 focus:ring-neutral-900 transition"></textarea>
          <p id="kontakti-error" class="hidden text-xs text-red-600"></p>
          <p id="kontakti-success" class="hidden text-xs text-green-700">Thank you! Your message has been sent.</p>
          <button id="kontakti-submit" type="submit" class="w-full inline-flex items-center justify-center px-6 py-3.5 rounded-xl border border-black text-black text-xs font-bold tracking-widest uppercase transition-colors duration-200 hover:opacity-90" style="background:#8AE14A;">
            Send
          </button>
        </form>
      </div>
    </div>
  </div>
  <script>
    (function () {
      const modal = document.getElementById('kontakti-modal');
      if (!modal || modal.dataset.kontaktiInit === '1') return;
      modal.dataset.kontaktiInit = '1';
      const openers = document.querySelectorAll('[data-kontakti-open]');
      const closeBtn = document.getElementById('kontakti-close');
      const backdrop = document.getElementById('kontakti-backdrop');
      const form = document.getElementById('kontakti-form');
      const submit = document.getElementById('kontakti-submit');
      const errEl = document.getElementById('kontakti-error');
      const okEl = document.getElementById('kontakti-success');
      function open() { modal.classList.remove('hidden'); document.body.style.overflow = 'hidden'; }
      function close() { modal.classList.add('hidden'); document.body.style.overflow = ''; }
      openers.forEach(a => a.addEventListener('click', (e) => { e.preventDefault(); open(); }));
      if (closeBtn) closeBtn.addEventListener('click', close);
      if (backdrop) backdrop.addEventListener('click', close);
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !modal.classList.contains('hidden')) close();
      });
      if (form) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          const name = document.getElementById('kontakti-name').value.trim();
          const email = document.getElementById('kontakti-email').value.trim();
          const phone = document.getElementById('kontakti-phone').value.trim();
          const comment = document.getElementById('kontakti-comment').value.trim();
          if (!comment) {
            errEl.textContent = 'Please enter a message.';
            errEl.classList.remove('hidden');
            okEl.classList.add('hidden');
            return;
          }
          if (!email && !phone) {
            errEl.textContent = 'Please provide an email or phone so we can reach you.';
            errEl.classList.remove('hidden');
            okEl.classList.add('hidden');
            return;
          }
          errEl.classList.add('hidden');
          const orig = submit.textContent;
          submit.disabled = true;
          submit.textContent = 'Sending…';
          try {
            const res = await fetch('https://api.web3forms.com/submit', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
              body: JSON.stringify({
                access_key: RK_WEB3.key,
              cc: RK_WEB3.cc,
                subject: 'Contact form — ResonateKit',
                from_name: 'ResonateKit — Contact form',
                name: name || '—',
                email: email || '—',
                phone: phone || '—',
                comment: comment
              })
            });
            const d = await res.json();
            if (d && d.success) {
              okEl.classList.remove('hidden');
              errEl.classList.add('hidden');
              form.reset();
            } else {
              errEl.textContent = (d && d.message) || 'Error. Please email hello@resonatekit.com';
              errEl.classList.remove('hidden');
            }
          } catch (err) {
            errEl.textContent = 'Network error. Please email hello@resonatekit.com';
            errEl.classList.remove('hidden');
          } finally {
            submit.disabled = false;
            submit.textContent = orig;
          }
        });
      }
    })();

    // ==== Lightweight analytics events → GA4 (gtag) + Meta Pixel (fbq) ====
    (function () {
      const ga = (...args) => { try { (window.gtag || function () {})(...args); } catch (e) {} };
      const fb = (...args) => { try { (window.fbq || function () {})(...args); } catch (e) {} };

      document.addEventListener('click', (e) => {
        const a = e.target.closest('a, button');
        if (!a) return;
        const href = (a.getAttribute('href') || '').toLowerCase();
        const label = (a.textContent || '').trim().slice(0, 60);
        if (href.startsWith('mailto:')) { ga('event', 'click_email'); fb('track', 'Contact'); }
        else if (href.startsWith('tel:')) { ga('event', 'click_phone'); fb('track', 'Contact'); }
        else if (a.hasAttribute('data-kontakti-open')) { ga('event', 'open_contact'); }
        else if (a.classList.contains('hero-cta')) { ga('event', 'click_cta', { label: label || 'cta' }); }
      }, { passive: true });

      // Lead form submissions → GA4 generate_lead + Meta Lead
      [
        { btn: 'qs-submit', confirm: 'qs-confirmed', name: 'proposal' },
        { btn: 'corp-form-submit', confirm: null, name: 'corporate' },
      ].forEach(({ btn, confirm, name }) => {
        const b = document.getElementById(btn);
        if (!b) return;
        b.addEventListener('click', () => setTimeout(() => {
          ga('event', 'generate_lead', { lead_type: name });
          fb('track', 'Lead', { content_name: name });
        }, 200));
      });
    })();
  </script>

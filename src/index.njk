              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
              body: JSON.stringify(payload)
            });
            const data = await res.json();
            if (data && data.success) {
              corpForm.innerHTML =
                '<div class="text-center py-4">' +
                  '<div class="w-12 h-12 rounded-full bg-[#f5f0eb] border border-neutral-200 flex items-center justify-center mx-auto mb-4">' +
                    '<svg class="w-6 h-6 text-[#2f7a3d]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75" /></svg>' +

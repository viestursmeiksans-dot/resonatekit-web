      function populateCorpDetail(value) {
        const data = corporateContent[value];
        if (!data || !corpDetail) return;
        document.getElementById('corp-kicker').textContent = data.kicker;
        document.getElementById('corp-title').textContent = data.title;
        document.getElementById('corp-desc').textContent = data.desc;
        const metaEl = document.getElementById('corp-meta');
        metaEl.innerHTML = '';
        (data.meta || []).forEach(m => {
          const s = document.createElement('span');
          s.className = 'inline-flex items-center bg-neutral-100 text-neutral-600 text-xs font-medium px-3 py-1 rounded-full';
          s.textContent = m; metaEl.appendChild(s);
        });
        const bulletsEl = document.getElementById('corp-bullets');
        bulletsEl.innerHTML = '';
        (data.bullets || []).forEach(b => {
          const li = document.createElement('li');
          li.className = 'flex items-start gap-2';
          li.innerHTML = '<span class="text-[#3d2d5e] mt-0.5">✓</span><span>' + b + '</span>';
          bulletsEl.appendChild(li);
